{
  "version": "0.0.1",
  "autoPort": true,
  "configurations": [
    {
      "name": "Static server (python http.server)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "$PORT"]
    },
    {
      "name": "Static server (npx http-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "$PORT", "-c-1"]
    }
  ]
}
